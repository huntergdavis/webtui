#!/bin/bash
# vault-lock — drop all identities from ssh-agent (clears the decrypted key from RAM).
# Safe to run repeatedly and from the host (idle/blur auto-lock): never errors just because
# the vault is already locked. The agent process keeps running (empty) on its socket so a
# later vault-unlock can reuse it.
set -uo pipefail

SOCK="$HOME/.ssh-agent.sock"
if [ -S "$SOCK" ]; then
  SSH_AUTH_SOCK="$SOCK" ssh-add -D >/dev/null 2>&1 || true
fi
echo "vault-lock: ssh-agent identities cleared (key removed from memory)."
