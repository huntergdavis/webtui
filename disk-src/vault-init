#!/bin/bash
# vault-init — create an ed25519 SSH key and seal the PRIVATE key with age (PLAN §8.1,
# the R1 fix). The CheerpX guest has no writable RAM filesystem (tmpfs isn't implemented;
# DataDevice mounts are guest-read-only), so the decrypted key is never kept on a mount:
# it lives only in ssh-agent memory after `vault-unlock` (see that script). At rest only
# the age ciphertext (~/.ssh.age) is on the persisted disk; the public key is not secret.
set -euo pipefail

VAULT="$HOME/.ssh.age"
PUB="$HOME/.ssh/id_ed25519.pub"

if [ -f "$VAULT" ]; then
  echo "vault-init: $VAULT already exists. Use 'vault-unlock', or remove it first." >&2
  exit 1
fi

umask 077
mkdir -p "$HOME/.ssh"

read -r -p "Comment/label for this key (e.g. you@browser): " COMMENT
COMMENT="${COMMENT:-webtui@browser}"

# ssh-keygen must write to a file; use a temp, seal it, then shred. This brief moment is
# the only time plaintext touches the (persisted) disk — minimized + shredded, init-only.
TMP="$(mktemp -d)"
trap 'shred -u "$TMP"/id_ed25519 2>/dev/null || rm -f "$TMP"/id_ed25519; rm -rf "$TMP"' EXIT

echo "==> generating ed25519 keypair"
ssh-keygen -t ed25519 -N "" -C "$COMMENT" -f "$TMP/id_ed25519" -q

echo "==> sealing the PRIVATE key into $VAULT (choose a STRONG age passphrase)"
age -p -o "$VAULT" "$TMP/id_ed25519"
chmod 600 "$VAULT"
install -m 0644 "$TMP/id_ed25519.pub" "$PUB"

echo
echo "==> done. Your PUBLIC key (add to GitHub -> Settings -> SSH keys):"
echo "------------------------------------------------------------------------"
cat "$PUB"
echo "------------------------------------------------------------------------"
echo "Run 'vault-unlock' to load the key into ssh-agent; 'vault-lock' to clear it."
