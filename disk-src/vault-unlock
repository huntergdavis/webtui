#!/bin/bash
# vault-unlock — decrypt the sealed private key and stream it straight into ssh-agent
# (PLAN §8.1). The plaintext key is NEVER written to a filesystem: `age -d` writes it to
# stdout and we pipe it into `ssh-add -` (reads the key from stdin), so it exists only in
# the agent's process memory (guest RAM, gone on reload). The agent listens on a fixed
# socket in $HOME so other shells and the host Lock button find it; the socket is not
# secret (it carries no key material at rest).
set -euo pipefail

VAULT="$HOME/.ssh.age"
SOCK="$HOME/.ssh-agent.sock"
TTL="${VAULT_TTL:-1800}"   # seconds the key stays loaded (default 30 min)

if [ ! -f "$VAULT" ]; then
  echo "vault-unlock: no vault at $VAULT. Run 'vault-init' first." >&2
  exit 1
fi

# Reuse a live agent on the fixed socket, else start a fresh one there.
if [ ! -S "$SOCK" ] || ! SSH_AUTH_SOCK="$SOCK" ssh-add -l >/dev/null 2>&1; then
  rm -f "$SOCK"
  eval "$(ssh-agent -a "$SOCK")" >/dev/null
fi
export SSH_AUTH_SOCK="$SOCK"

echo "==> decrypting vault (enter your age passphrase)"
# age prompts on the tty; its stdout (the decrypted key) pipes into the agent.
age -d "$VAULT" | ssh-add -t "$TTL" -

echo "==> unlocked. Key loaded into ssh-agent for ${TTL}s (RAM only). SSH_AUTH_SOCK=$SOCK"
echo "    New shells pick up the agent automatically; run 'vault-lock' to clear it."
